# Python 缓存
__pycache__/
*.py[cod]

# 测试和代码检查缓存
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Python 打包产物
*.egg-info/
build/
dist/

# 环境变量和密钥
.env
.env.*

# 日志文件
logs/*.log

# 原始数据和中间数据
data/raw/*
data/interim/*
data/processed/*

# 保留空目录
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# 编辑器配置
.vscode/
.idea/

# 系统文件
.DS_Store